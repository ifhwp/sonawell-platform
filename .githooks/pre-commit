#!/usr/bin/env bash
#
# pre-commit hook -- blocks secrets and personal data from this PUBLIC
# repo (sonawell-platform).
#
# Activate it once per clone:   git config core.hooksPath .githooks
#
# Optional: copy private-paths.local.example to private-paths.local
# (same folder, gitignored) to also block project-private file paths.
#
# Bypass for a confirmed false positive:   git commit --no-verify
#

fail=0
errs=()

staged="$(git diff --cached --name-only --diff-filter=ACM)"

# 1) Sensitive filenames -------------------------------------------------
while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$(basename "$f")" in
    .env.example) ;;                                  # empty template, allowed
    .env|.env.local|.env.*) errs+=("env file staged: $f"); fail=1 ;;
  esac
  case "$f" in
    *.pem|*.p12|*.pfx|*.keystore|*id_rsa|*id_ed25519)
      errs+=("key/cert file staged: $f"); fail=1 ;;
  esac
done < <(printf '%s\n' "$staged")

# 2) Project-private paths -- optional, from a gitignored local file -----
root="$(git rev-parse --show-toplevel)"
local_paths="$root/.githooks/private-paths.local"
if [ -f "$local_paths" ]; then
  while IFS= read -r pat; do
    [ -z "$pat" ] && continue
    case "$pat" in \#*) continue ;; esac
    if printf '%s\n' "$staged" | grep -Fq -e "$pat"; then
      hit="$(printf '%s\n' "$staged" | grep -F -e "$pat" | head -n1)"
      errs+=("project-private path: $hit"); fail=1
    fi
  done < "$local_paths"
fi

# 3) Secret patterns in added lines --------------------------------------
added="$(git diff --cached --diff-filter=ACM -U0 | grep -E '^\+' | grep -Ev '^\+\+\+')"
Q="[\"']"

check() {
  if printf '%s\n' "$added" | grep -Eq -e "$2"; then
    errs+=("$1"); fail=1
  fi
}

check "private key block"        '-----BEGIN [A-Z ]*PRIVATE KEY-----'
check "AWS access key id"        'AKIA[0-9A-Z]{16}'
check "Anthropic API key"        'sk-ant-[A-Za-z0-9_-]{20,}'
check "OpenAI-style API key"     'sk-[A-Za-z0-9]{32,}'
check "GitHub token"             'gh[pousr]_[A-Za-z0-9]{20,}'
check "Slack token"              'xox[baprs]-[A-Za-z0-9-]{10,}'
check "Google API key"           'AIza[0-9A-Za-z_-]{30,}'
check "Kit/ConvertKit secret"    "KIT_(API_KEY|FORM_ID|TAG_[A-Z_]+)[[:space:]]*[:=][[:space:]]*${Q}?[A-Za-z0-9]"
check "assigned secret/password" "(secret|token|passwd|password|api[_-]?key|access[_-]?key|auth[_-]?token)${Q}?[[:space:]]*[:=][[:space:]]*${Q}[A-Za-z0-9/_+=.-]{8,}${Q}"

# 4) Personal data -------------------------------------------------------
check "phone number (intl)"      '\+[0-9]{1,3}[ .-][0-9]{2,4}[ .-]?[0-9]{2,4}[ .-]?[0-9]{2,6}'
check "phone number (US)"        '\(?[0-9]{3}\)?[ .-][0-9]{3}[ .-][0-9]{4}'
check "SSN pattern"              '[0-9]{3}-[0-9]{2}-[0-9]{4}'
check "credit-card pattern"      '[0-9]{4}[ -][0-9]{4}[ -][0-9]{4}[ -][0-9]{4}'

emails="$(printf '%s\n' "$added" | grep -Eio '[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}' | grep -Eiv '@(example\.(com|org|net)|test\.(com|org)|domain\.com|email\.com|yourdomain\.com|acme\.com|sentry\.io)$' | grep -Eiv '\.test$')"
if [ -n "$emails" ]; then
  errs+=("email address: $(printf '%s' "$emails" | head -n1)")
  fail=1
fi

# 5) Report --------------------------------------------------------------
if [ "$fail" -ne 0 ]; then
  echo ""
  echo "X commit blocked -- possible sensitive content in this PUBLIC repo:"
  for e in "${errs[@]}"; do echo "    - $e"; done
  echo ""
  echo "  Inspect:  git diff --cached"
  echo "  If it is genuinely safe, bypass with:  git commit --no-verify"
  echo ""
  exit 1
fi
exit 0

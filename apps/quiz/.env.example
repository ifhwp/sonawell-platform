# SonaWell Midlife Quiz — environment variables
#
# Copy to `.env.local` for local dev (already gitignored).
# Set these on Vercel via: Project → Settings → Environment Variables.
#
# Without any of these set, the app still runs and the quiz works end-to-end;
# the /api/submit handler will skip the Kit subscribe and log instead.

# ───────────────────────────────────────────────────────────
# Kit (formerly ConvertKit) — required for ESP / email automation
# ───────────────────────────────────────────────────────────

# Account API key. Find at: https://app.kit.com/account_settings/advanced_settings
KIT_API_KEY=

# Form ID the quiz subscribes people to.
# Create a form in Kit, then grab the numeric id from its URL.
KIT_FORM_ID=

# Tag IDs (one per archetype). Create the four tags in Kit, then look up each id.
# These trigger the matching welcome sequence per the spec.
KIT_TAG_HORMONE=
KIT_TAG_INSULIN=
KIT_TAG_CORTISOL=
KIT_TAG_MUSCLE_LOSS=

# ───────────────────────────────────────────────────────────
# Failed-lead fallback — durable capture when Kit subscribe fails
# ───────────────────────────────────────────────────────────
#
# Slack or Discord incoming webhook. When set, a failed Kit subscribe is
# posted here with the lead's name + email + archetype, so the lead can be
# recovered manually. Without it, failed leads are still visible in Vercel
# function logs (still better than the previous silent failure).

FAILED_LEAD_WEBHOOK_URL=

# Webhook payload format: "slack" (default) or "discord".
# Slack expects { text: ... }; Discord expects { content: ... }.
FAILED_LEAD_WEBHOOK_KIND=
